{
  "name": "@lazily-hub/js",
  "version": "0.2.0",
  "description": "JavaScript lazily IPC protocol helpers plus FFI state-projection consumer bindings. NOT a reactive-core port.",
  "type": "module",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./state-projection": {
      "types": "./src/state-projection.d.ts",
      "default": "./src/state-projection.js"
    },
    "./statechart": {
      "types": "./src/statechart.d.ts",
      "default": "./src/statechart.js"
    }
  },
  "scripts": {
    "build": "node --check src/index.js && node --check src/state-projection.js && node --check src/statechart.js",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "koffi": "^3.0.2"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
